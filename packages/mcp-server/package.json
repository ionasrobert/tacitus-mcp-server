{
  "name": "@dashiro/tacitus-mcp-server",
  "version": "0.1.0",
  "description": "Tacitus Memory \u2014 an MCP server giving AI agents long-term memory with provenance, token budgeting, and conflict detection.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "mcp",
    "agent-memory",
    "pkm",
    "knowledge-base",
    "model-context-protocol"
  ],
  "bin": {
    "tacitus-mcp": "dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
